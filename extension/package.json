{
  "name": "jessie-ai",
  "displayName": "Jessie — AI Coding Agent",
  "description": "Jessie v3 — hosted BYOK AI coding agent. Code Review, Merge Review, tickets. Your API key stays on your device.",
  "version": "3.0.0",
  "publisher": "VijayArther",
  "icon": "media/jessie-128.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Arther100/jessie-ai"
  },
  "bugs": { "url": "https://github.com/Arther100/jessie-ai/issues" },
  "homepage": "https://github.com/Arther100/jessie-ai#readme",
  "keywords": ["ai", "copilot", "agent", "prompt", "code quality", "rag", "assistant", "code review", "merge review", "azure", "claude"],
  "license": "MIT",
  "engines": { "vscode": "^1.90.0" },
  "categories": ["AI", "Programming Languages", "Other"],
  "galleryBanner": { "color": "#1a1a2e", "theme": "dark" },
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "jessie",
        "name": "jessie",
        "fullName": "Jessie AI",
        "description": "Coaches your prompt, injects codebase context, picks the right model, and quality-checks the output — automatically.",
        "isSticky": true
      }
    ],
    "commands": [
      { "command": "jessie.ask",           "title": "Ask Jessie",                    "category": "Jessie" },
      { "command": "jessie.setup",         "title": "Setup Jessie",                  "category": "Jessie" },
      { "command": "jessie.showRequests",  "title": "My Request Count Today",        "category": "Jessie" },
      { "command": "jessie.tour",          "title": "How to Use Jessie",             "category": "Jessie" },
      { "command": "jessie.reviewProject", "title": "Code Review",                   "category": "Jessie", "icon": "$(search)" },
      { "command": "jessie.reviewAzure",   "title": "Code Review (Azure Branch)",    "category": "Jessie", "icon": "$(cloud)" },
      { "command": "jessie.mergeReview",   "title": "Merge Review",                  "category": "Jessie", "icon": "$(git-merge)" },
      { "command": "jessie.history",       "title": "History",                       "category": "Jessie", "icon": "$(history)" },
      { "command": "jessie.settings",      "title": "Settings",                      "category": "Jessie", "icon": "$(gear)" },
      { "command": "jessie.info",          "title": "Info (Claude key)",              "category": "Jessie", "icon": "$(info)" },
      { "command": "jessie.updateApiKey",  "title": "Update API Key",                "category": "Jessie", "icon": "$(key)" },
      { "command": "jessie.checkApiKey",   "title": "Check API Key Status",          "category": "Jessie", "icon": "$(shield)" },
      { "command": "jessie.fixTicket",      "title": "Fix Ticket",                     "category": "Jessie", "icon": "$(issues)" },
      { "command": "jessie.scanSprint",      "title": "Scan Sprint Board",              "category": "Jessie", "icon": "$(checklist)" },
      { "command": "jessie.openTicketBoard", "title": "Open Ticket Board",              "category": "Jessie", "icon": "$(project)" },
      { "command": "jessie.weeklyReport",    "title": "Generate Weekly Report",         "category": "Jessie", "icon": "$(graph)" }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "jessie.reviewProject",
          "when": "explorerResourceIsFolder",
          "group": "jessie@1"
        }
      ],
      "commandPalette": [
        { "command": "jessie.reviewAzure" },
        { "command": "jessie.mergeReview" },
        { "command": "jessie.history" },
        { "command": "jessie.settings" },
        { "command": "jessie.info" },
        { "command": "jessie.updateApiKey" },
        { "command": "jessie.checkApiKey" },
        { "command": "jessie.fixTicket" },
        { "command": "jessie.scanSprint" },
        { "command": "jessie.openTicketBoard" },
        { "command": "jessie.weeklyReport" }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        { "id": "jessie-sidebar", "title": "Jessie", "icon": "media/jessie.svg" }
      ]
    },
    "views": {
      "jessie-sidebar": [
        { "type": "webview", "id": "jessie.panel", "name": "Jessie AI" }
      ]
    },
    "configuration": {
      "title": "Jessie",
      "properties": {
        "jessie.userId": {
          "type": "string",
          "default": "",
          "description": "Your name or identifier"
        },
        "jessie.backendUrl": {
          "type": "string",
          "default": "https://jessie-ai-xpv2.onrender.com",
          "description": "Jessie backend URL. Pre-filled with the hosted Render server."
        },
        "jessie.aiProvider": {
          "type": "string",
          "enum": ["anthropic", "openai", "gemini"],
          "default": "anthropic",
          "description": "AI provider for Jessie"
        },
        "jessie.webAppUrl": {
          "type": "string", "default": "http://localhost:3000",
          "description": "Jessie web app URL (Dashboard / History in browser)."
        },
        "jessie.azureGitUrl": {
          "type": "string", "default": "",
          "description": "Last used Azure Git URL (https://dev.azure.com/{org}/{project}/_git/{repo})."
        },
        "jessie.ticketPlatform": {
          "type": "string",
          "enum": ["azure", "jira", "github", "linear"],
          "default": "azure",
          "description": "Default ticket platform for Jessie Fix Ticket / Sprint Board."
        },
        "jessie.autoFixOnAssign": {
          "type": "boolean",
          "default": false,
          "description": "Auto-start fix when ticket assigned to you in VS Code."
        },
        "jessie.cicdAutoFix": {
          "type": "boolean",
          "default": true,
          "description": "Auto-fix CI/CD failures when Jessie can handle them."
        },
        "jessie.azureOrg": {
          "type": "string", "default": "",
          "description": "Azure DevOps organisation for ticket boards."
        },
        "jessie.azureProject": {
          "type": "string", "default": "",
          "description": "Azure DevOps project for ticket boards."
        },
        "jessie.githubRepo": {
          "type": "string", "default": "",
          "description": "GitHub owner/repo for issues + PRs."
        }
      }
    },
    "keybindings": [
      { "command": "jessie.ask",           "key": "ctrl+shift+j", "mac": "cmd+shift+j" },
      { "command": "jessie.reviewProject", "key": "ctrl+shift+r", "mac": "cmd+shift+r" },
      { "command": "jessie.mergeReview",   "key": "ctrl+shift+m", "mac": "cmd+shift+m" },
      { "command": "jessie.fixTicket",     "key": "ctrl+shift+t", "mac": "cmd+shift+t" },
      { "command": "jessie.openTicketBoard","key": "ctrl+shift+b", "mac": "cmd+shift+b" }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch":   "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node":   "^20.0.0",
    "typescript":    "^5.4.0",
    "@vscode/vsce":  "^3.0.0"
  },
  "dependencies": {
    "axios": "^1.7.0"
  }
}
